{
  "name": "@casepilot/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "casepilot-server": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "default": "./dist/runner.js"
    },
    "./projects": {
      "types": "./dist/projects.d.ts",
      "default": "./dist/projects.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@casepilot/core": "*",
    "@casepilot/mcp": "*",
    "@casepilot/providers": "*",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "fastify": "^5.2.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
